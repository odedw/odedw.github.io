---
layout: layouts/default.njk
title: Talks
---

<div>
  <h1 class="text-3xl font-serif mb-10">Talks</h1>
  {% for talk in talks %}
    <article class="w-full md:w-4/5 mx-auto mb-16">
      <header class="mb-3">
        <h2 class="text-xl font-serif">{{ talk.title }}</h2>
        <div class="text-sm text-gray-400 mt-1">
          {{ talk.event }}{% if talk.event and talk.date %} &middot; {% endif %}{{ talk.date }}
        </div>
      </header>
      <div class="youtube-container">
        <iframe title="{{ talk.title }}" class="youtube" src="{{ talk.url }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
      {% if talk.description %}
        <p class="mt-3 text-sm">{{ talk.description }}</p>
      {% endif %}
      {% if talk.links %}
        <div class="mt-2 text-sm flex flex-wrap">
          {% for link in talk.links %}
            <a href="{{ link.url }}"{% if link.url[0] != "/" %} target="_blank" rel="noopener"{% endif %}>{{ link.label }}</a>
            {% if not loop.last %}<span class="mx-2">•</span>{% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </article>
  {% endfor %}
</div>
