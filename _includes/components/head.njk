<head>
    <meta charset="utf-8">
    <meta http-equiv="content-type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5">

    <title>
        {% if title %}{{ title }} &middot; {{ siteTitle }}
        {% else %}{{ siteTitle }}
        {% endif %}
    </title>

    {% set siteUrl = "https://www.odedwelgreen.com" %}
    {% set pageDescription = "Oded Welgreen — Head of Engineering at Spinach. Software engineer, musician and artist. Notes, projects, music and talks." %}
    {% set ogImage = siteUrl + "/images/profile-og.jpg" %}

    <meta name="description" content="{{ pageDescription }}">
    <meta name="author" content="Oded Welgreen">

    <meta property="og:type" content="website">
    <meta property="og:title" content="{% if title %}{{ title }} · {{ siteTitle }}{% else %}{{ siteTitle }}{% endif %}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:image" content="{{ ogImage }}">
    <meta property="og:url" content="{{ siteUrl }}">
    <meta property="og:site_name" content="{{ siteTitle }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% if title %}{{ title }} · {{ siteTitle }}{% else %}{{ siteTitle }}{% endif %}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ ogImage }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Lora:wght@500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets/main.css">
    <link rel="shortcut icon" href="/images/favicon.ico">
</head>
